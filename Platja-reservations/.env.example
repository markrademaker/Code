# --- Database ---
# DATABASE_URL is the pooled connection used at runtime.
# DATABASE_URL_UNPOOLED is a direct connection used for schema migrations
# (Prisma db push). Both are added automatically by the Vercel-Neon
# integration. Locally you can point both at the same Postgres URL.
DATABASE_URL=postgresql://user:password@localhost:5432/platja
DATABASE_URL_UNPOOLED=postgresql://user:password@localhost:5432/platja

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
BOOKING_FROM_EMAIL=onboarding@resend.dev
BOOKING_TO_EMAILS=neleman3@gmail.com,rademair@gmail.com

# --- Admin (RBAC) ---
# Comma-separated email addresses that have admin access. Anyone
# signing in to a regular user account with one of these emails
# gets the admin dashboard automatically. Leave unset to fall back
# to the hardcoded list in src/lib/admin-rbac.ts.
ADMIN_EMAILS=rademair@gmail.com,neleman3@gmail.com,mtrademaker@gmail.com
# Random 32+ byte string for signing the user session cookie
# (admin sessions piggyback on the same secret).
ADMIN_SESSION_SECRET=replace-me-with-a-long-random-string
# Random 32+ byte string for signing the accept/decline links in emails
BOOKING_ACTION_SECRET=replace-me-with-another-long-random-string

# Absolute URL of the deployed site (used to build email action links)
APP_BASE_URL=https://platja-reservations.vercel.app

# --- Google OAuth (optional) ---
# Configure at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: <APP_BASE_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe (optional) ---
# Create an account at https://dashboard.stripe.com
# Enable iDEAL and PayPal under Settings → Payment methods
# Webhook endpoint: <APP_BASE_URL>/api/stripe/webhook
#   listen for: checkout.session.completed,
#               checkout.session.async_payment_succeeded,
#               checkout.session.async_payment_failed
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
